 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>5 scans per month</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>8-dimension AEO analysis</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Instant PDF/CSV export</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Basic scan history (last 10)</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>No credit card required</li></ul><a class=\"block w-full py-3 text-center font-semibold rounded-xl border-2 border-gray-200 text-gray-700 hover:border-pulse-600 hover:text-pulse-600 transition-colors\" href=\"/\">Get Started Free</a></div><div class=\"bg-white rounded-2xl p-8 shadow-lg relative border-2 border-pulse-600\"><div class=\"absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-pulse-600 text-white text-xs font-bold rounded-full uppercase tracking-wide\">Most Popular</div><div class=\"text-sm font-semibold uppercase tracking-wide mb-2 text-pulse-600\">Pro</div><div class=\"flex items-baseline gap-1 mb-1\"><span class=\"text-4xl font-bold text-gray-900\">$<!-- -->9</span></div><p class=\"text-gray-400 text-sm mb-6\">one-time payment • 30 days access</p><ul class=\"space-y-3 text-left mb-8\"><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Unlimited scans</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Full 8-dimension AEO analysis</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Full scan history (up to 100)</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Multi-engine detection</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Batch scanning</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Engine simulation preview</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>Priority support</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><svg class=\"w-5 h-5 text-green-500 shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg>No auto-renewal</li></ul><div class=\"\"><div class=\"flex items-center justify-center gap-2 py-3\"><div class=\"w-5 h-5 border-2 border-gray-300 border-t-blue-600 rounded-full animate-spin\"></div><span class=\"text-sm text-gray-500\">Loading PayPal…</span></div><div class=\"pointer-events-none opacity-0 h-0 overflow-hidden\"></div></div><p class=\"text-xs text-gray-400 mt-3 text-center\">$<!-- -->9<!-- --> one-time payment · <!-- -->30<!-- --> days Pro · No auto-renewal · Pro activated automatically after payment</p></div></div><div class=\"max-w-2xl mx-auto\"><h2 class=\"text-2xl font-bold text-gray-900 mb-6 text-center\">FAQ</h2><div class=\"space-y-4\"><details class=\"group bg-white rounded-xl border border-gray-200 p-5\"><summary class=\"font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between\">How long does Pro last?<svg class=\"w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></summary><p class=\"text-sm text-gray-500 mt-3 leading-relaxed\">Pro access is valid for 30 days from the date of purchase.</p></details><details class=\"group bg-white rounded-xl border border-gray-200 p-5\"><summary class=\"font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between\">Will I be charged automatically?<svg class=\"w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></summary><p class=\"text-sm text-gray-500 mt-3 leading-relaxed\">No. AnswerPulse Pro is a one-time payment with no auto-renewal. You choose when to renew.</p></details><details class=\"group bg-white rounded-xl border border-gray-200 p-5\"><summary class=\"font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between\">How do I renew my Pro access?<svg class=\"w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></summary><p class=\"text-sm text-gray-500 mt-3 leading-relaxed\">After your 30-day access expires, you can manually purchase Pro again at any time from the Pricing page.</p></details><details class=\"group bg-white rounded-xl border border-gray-200 p-5\"><summary class=\"font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between\">What happens when my Pro expires?<svg class=\"w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></summary><p class=\"text-sm text-gray-500 mt-3 leading-relaxed\">Your account returns to the Free plan. You can continue using free features, or renew Pro whenever you&#x27;re ready.</p></details><details class=\"group bg-white rounded-xl border border-gray-200 p-5\"><summary class=\"font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between\">How does PayPal payment work?<svg class=\"w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></summary><p class=\"text-sm text-gray-500 mt-3 leading-relaxed\">Click the PayPal Checkout button on the Pro plan to pay securely. After payment is confirmed, your Pro plan is activated instantly — no waiting, no manual steps.</p></details><details class=\"group bg-white rounded-xl border border-gray-200 p-5\"><summary class=\"font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between\">What happens after I pay?<svg class=\"w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></summary><p class=\"text-sm text-gray-500 mt-3 leading-relaxed\">Your Pro access is activated instantly after payment confirmation. You&#x27;ll get unlimited scans, full history, and all Pro features immediately. If anything goes wrong, contact support.</p></details><details class=\"group bg-white rounded-xl border border-gray-200 p-5\"><summary class=\"font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between\">Is there a refund policy?<svg class=\"w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></summary><p class=\"text-sm text-gray-500 mt-3 leading-relaxed\">Refunds can be requested within 7 days of purchase. If you have used Pro features more than 5 times, refunds are not supported. Contact support@answerpulse.com for assistance.</p></details><details class=\"group bg-white rounded-xl border border-gray-200 p-5\"><summary class=\"font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between\">Is there a free trial?<svg class=\"w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></summary><p class=\"text-sm text-gray-500 mt-3 leading-relaxed\">The free plan includes 5 scans per month — no trial needed. Use it to see the value before upgrading.</p></details></div></div></main><footer class=\"py-8 px-4 border-t border-gray-200 bg-white\"><div class=\"max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-400\"><div class=\"flex items-center gap-2\"><span class=\"text-pulse-600 font-bold\">AnswerPulse</span><span>© <!-- -->2026</span></div><div class=\"flex items-center gap-6\"><a class=\"hover:text-gray-600\" href=\"/privacy\">Privacy Policy</a></div></div></footer></div><script src=\"/_next/static/chunks/webpack-f003815dc861492f.js\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0]);self.__next_f.push([2,null])</script><script>self.__next_f.push([1,\"1:HL[\\\"/_next/static/css/1ac20fd96f21f7cb.css\\\",\\\"style\\\"]\\n\