# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# PayPal Payment Link
# Create a PayPal payment button/link at https://www.paypal.com/buttons/smart
# Then paste the full checkout URL here (starts with https://www.paypal.com/...)
# Leave empty or set to "#" to show "Upgrade Coming Soon" button
NEXT_PUBLIC_PAYPAL_PAYMENT_LINK=https://www.paypal.com/your-payment-link-here

